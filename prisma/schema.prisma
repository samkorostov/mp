generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum MeetingStatus {
  DRAFT
  OPEN
  LOCKED
  RESOLVED
}

enum LegKind {
  MONEYLINE
  OVER_UNDER
}

enum LegStatus {
  OPEN
  LOCKED
  RESOLVED
  VOID
}

enum WinningSide {
  A
  B
  PUSH
  VOID
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BetKind {
  SINGLE
  PARLAY
}

enum BetStatus {
  PENDING
  WON
  LOST
  PUSH
  VOID
}

enum SelectionSide {
  A
  B
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  points        Int       @default(1000)
  createdAt     DateTime  @default(now())

  accounts     Account[]
  sessions     Session[]
  bets         Bet[]
  proposals    LegProposal[]
  meetings     Meeting[]     @relation("CreatedBy")
}

model Meeting {
  id          String        @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  status      MeetingStatus @default(OPEN)
  createdById String
  createdAt   DateTime      @default(now())

  createdBy User          @relation("CreatedBy", fields: [createdById], references: [id])
  legs      Leg[]
  bets      Bet[]
  proposals LegProposal[]
}

model Leg {
  id          String      @id @default(cuid())
  meetingId   String
  kind        LegKind
  prompt      String
  line        Float?
  sideALabel  String
  sideBLabel  String
  status      LegStatus   @default(OPEN)
  winningSide WinningSide?
  actualValue Float?
  createdAt   DateTime    @default(now())

  meeting    Meeting        @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  selections BetSelection[]
}

model LegProposal {
  id         String         @id @default(cuid())
  meetingId  String
  proposerId String
  kind       LegKind
  prompt     String
  line       Float?
  status     ProposalStatus @default(PENDING)
  createdAt  DateTime       @default(now())

  meeting  Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  proposer User    @relation(fields: [proposerId], references: [id])
}

model Bet {
  id        String    @id @default(cuid())
  userId    String
  meetingId String
  kind      BetKind
  stake     Int
  status    BetStatus @default(PENDING)
  payout    Int?
  placedAt  DateTime  @default(now())

  user       User           @relation(fields: [userId], references: [id])
  meeting    Meeting        @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  selections BetSelection[]
}

model BetSelection {
  id    String        @id @default(cuid())
  betId String
  legId String
  side  SelectionSide

  bet Bet @relation(fields: [betId], references: [id], onDelete: Cascade)
  leg Leg @relation(fields: [legId], references: [id], onDelete: Cascade)

  @@unique([betId, legId])
}
